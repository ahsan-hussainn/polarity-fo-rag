# Copy to .env (gitignored) and fill in. Never commit real credentials.

# Supabase Postgres connection string.
# Dashboard -> Connect -> "Session pooler"  (IPv4, port 5432).
#   - NOT "Direct connection"    -> IPv6-only, unreachable from most local machines.
#   - NOT "Transaction pooler"   -> port 6543, breaks psycopg's prepared statements.
# Replace [YOUR-PASSWORD] with the database password you set when creating the project.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
